FROM python:3.11-slim

WORKDIR /app

COPY services/management-api/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY services/management-api/ /app/services/management-api/
COPY RELEASE_NOTES.md /app/
COPY CHANGELOG.md /app/
COPY VERSION /app/

ENV PYTHONPATH=/app

EXPOSE 8000

CMD ["uvicorn", "services.management-api.main:app", "--host", "0.0.0.0", "--port", "8000"]
