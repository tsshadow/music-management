# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_USER=music-management
DB_PASS=<>
DB_DB=music-management
MYSQL_ROOT_PASSWORD=

# App Configuration
debug=True
import_folder_path=/mnt/music/EPs/__TODO
music_folder_path=/mnt/music
eps_folder_path=/mnt/music/EPs
delimiter=/

# Host Paths (adjust if your host music path is different)
HOST_MUSIC_PATH=/mnt/music
HOST_DATA_PATH=/docker/music-management

# Downloader Settings
youtube_folder=/mnt/music/Youtube
youtube_archive=/mnt/music/archives/youtube
youtube_accounts=/mnt/music/Youtube/accounts.txt
soundcloud_folder=/mnt/music/Soundcloud
soundcloud_archive=/mnt/music/archives/soundcloud
soundcloud_accounts=/mnt/music/Soundcloud/accounts.txt
telegram_folder=/mnt/music/Telegram

# Telegram API (Get these from my.telegram.org)
telegram_api_id=
telegram_api_hash=
telegram_session=music-management
telegram_accounts=

# Docker Configuration
DOCKER_USER=tsshadow
IMAGE_ML=music-management-ml
IMAGE_TOOLS=music-management-tools
IMAGE_APP=music-management
IMAGE_MANAGEMENT=music-management-control

# Remote Deployment (optional)
# Descriptive name for the deployment target (e.g., "Production Stack")
DEPLOY_TARGET_NAME=

# Option 1: Portainer Webhook (Recommended if using Portainer Stacks)
PORTAINER_WEBHOOK_URL=

# Option 2: SSH-based deployment
REMOTE_HOST=
REMOTE_USER=
REMOTE_PASS=
# Path to docker-compose.yml or its directory on the remote host
REMOTE_STACK_PATH=
