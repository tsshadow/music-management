# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_USER=music-management
DB_PASS=<>
DB_DB=music-management

# App Configuration
debug=True
import_folder_path=/path/to/import
music_folder_path=/path/to/music
eps_folder_path=/path/to/eps
delimiter=/

# Remote Deployment (optional)
# Descriptive name for the deployment target (e.g., "Production Stack")
DEPLOY_TARGET_NAME=

# Option 1: Portainer Webhook (Recommended if using Portainer Stacks)
PORTAINER_WEBHOOK_URL=

# Option 2: SSH-based deployment
REMOTE_HOST=
REMOTE_USER=
REMOTE_PASS=
# Path to docker-compose.yml on the remote host
REMOTE_DOCKER_COMPOSE_PATH=
